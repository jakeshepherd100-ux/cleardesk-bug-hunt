generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Candidate {
  id          String   @id @default(cuid())
  name        String
  email       String   @unique
  startedAt   DateTime @default(now())
  totalScore  Int      @default(0)
  submissions Submission[]
}

model Submission {
  id            String    @id @default(cuid())
  candidateId   String
  candidate     Candidate @relation(fields: [candidateId], references: [id])
  bugId         String
  description   String
  prompt        String
  score         Int?
  scoreLabel    String?
  feedback      String?
  submittedAt   DateTime  @default(now())
}

model RtmProfile {
  id           String   @id @default(cuid())
  name         String
  roleType     String
  yearsExp     Int
  skills       String[]
  coreApps     String[]
  bio          String
  availability String
}

model BugDefinition {
  id              String   @id
  tier            String
  title           String
  description     String
  idealFixSummary String
  prerequisiteIds String[]
  points          Int
}
